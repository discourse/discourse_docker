#!/bin/bash
# fetch-asset URL SHA256 DEST
#
# sha-pinned download with a content-addressed cache. The cache directory is
# a BuildKit cache mount (see the base Dockerfile), so rebuilding a layer
# reuses earlier downloads instead of the network. The cache is shared across
# platforms: entries are keyed by the pinned sha256, so identical sources are
# fetched once for amd64 and arm64 while per-arch assets land under their own
# keys. Integrity never depends on the cache — entries are re-verified on
# every hit and anything that fails verification is discarded and re-fetched.
set -e

URL="$1"
SHA="$2"
DEST="$3"

if [ -z "$URL" ] || [ -z "$SHA" ] || [ -z "$DEST" ]; then
  echo "usage: fetch-asset URL SHA256 DEST" >&2
  exit 1
fi

CACHE_DIR="${ASSET_CACHE_DIR:-/var/cache/assets}"
CACHED="$CACHE_DIR/$SHA"

if [ -f "$CACHED" ]; then
  if echo "$SHA $CACHED" | sha256sum -c; then
    echo "fetch-asset: cache hit for $URL"
    cp "$CACHED" "$DEST"
    exit 0
  fi
  echo "fetch-asset: discarding corrupt cache entry for $URL" >&2
  rm -f "$CACHED"
fi

mkdir -p "$CACHE_DIR"
TMP=$(mktemp "$CACHE_DIR/.fetch.XXXXXXXX")
trap 'rm -f "$TMP"' EXIT
wget -q -O "$TMP" "$URL"
sha256sum "$TMP"
echo "$SHA $TMP" | sha256sum -c
# atomic publish: concurrent builds (e.g. parallel multi-platform) can race
# on the same key without ever exposing a partial file
mv "$TMP" "$CACHED"
cp "$CACHED" "$DEST"
